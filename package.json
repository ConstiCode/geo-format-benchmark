{
  "name": "geo-format-benchmark",
  "version": "0.1.0",
  "description": "Benchmark: Do LLMs cite structured data (JSON-LD, Markdown) more often than raw HTML?",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.87.0",
    "@google/generative-ai": "^0.24.1",
    "@mozilla/readability": "^0.6.0",
    "cheerio": "^1.0.0",
    "dotenv": "^17.4.1",
    "drizzle-orm": "^0.45.2",
    "express": "^4.21.0",
    "firebase-admin": "^13.8.0",
    "jsdom": "^25.0.0",
    "openai": "^6.34.0",
    "pg": "^8.13.0",
    "serpapi": "^2.2.1",
    "turndown": "^7.2.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/jsdom": "^21.1.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "@types/turndown": "^5.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "drizzle-kit": "^0.18.1",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.4"
  }
}
